# Mongo
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=changeme
ME_WEB_USER=me_admin
ME_WEB_PASSWORD=changeme

# Backend
PORT=3000
NODE_ENV=production
JWT_SECRET=changeme-long-random-string
JWT_EXPIRE=7d
# Access tokens are short-lived and verified by JWT_SECRET (above).
JWT_ACCESS_EXPIRE=15m
# Refresh tokens are long-lived, stored in the `refresh_tokens` collection, and
# rotated on every use. A separate secret is used if you later switch to signed
# refresh JWTs; today they are opaque uuids so this is reserved for that case.
JWT_REFRESH_EXPIRE=7d
JWT_REFRESH_SECRET=changeme-different-from-jwt-secret
# Redis is used for the token blacklist (logout + logout-everywhere).
# Full stack: set automatically by docker-compose (redis://redis:6379).
# Local dev against backend/docker-compose.yml: redis://localhost:6379
REDIS_URL=redis://redis:6379
MAX_FILE_SIZE=10485760
GEMINI_API_KEY=your-key-here
PUBLIC_BASE_URL=

# Docker-only overrides (set in compose, listed here for reference)
# MONGO_HOST=mongo
